# Brewfile —— 一键安装所有依赖： brew bundle --file=Brewfile
# ─────────────────────────────────────────────
# 终端模拟器
cask "iterm2"

# 现代化命令行工具
brew "starship"   # 提示符
brew "eza"        # ls 替代
brew "bat"        # cat 替代
brew "fzf"        # 模糊搜索
brew "fd"         # find 替代
brew "zoxide"     # 智能 cd
brew "ripgrep"    # grep 替代
brew "atuin"      # 历史管理

# zsh 增强插件
brew "zsh-autosuggestions"      # 历史灰色补全
brew "zsh-syntax-highlighting"  # 命令语法高亮

# 字体
cask "font-blex-mono-nerd-font"   # 主字体：IBM Plex Mono + Nerd 图标
cask "font-lxgw-wenkai"           # 中文副字体：霞鹜文楷（含 Mono）
cask "font-hack-nerd-font"        # 备用 Nerd 字体
