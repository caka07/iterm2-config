

# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/opt/homebrew/anaconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/homebrew/anaconda3/etc/profile.d/conda.sh" ]; then
        . "/opt/homebrew/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="/opt/homebrew/anaconda3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

export PATH="$HOME/.local/bin:$PATH"

# Homebrew (ensures /opt/homebrew/bin — including bun — is on PATH)
eval "$(/opt/homebrew/bin/brew shellenv)"

# Claude Code: skip all permission prompts (YOLO mode) — use only in trusted repos
alias yolo='claude --dangerously-skip-permissions'

# ─────────────────────────────────────────────────────────────
# 现代化命令行工具
# ─────────────────────────────────────────────────────────────

# starship —— 美化命令行提示符
eval "$(starship init zsh)"

# zoxide —— 智能 cd，用 `z <部分名称>` 跳转到常去的目录
eval "$(zoxide init zsh)"

# atuin —— 历史记录管理，Ctrl-R 进行全文搜索
eval "$(atuin init zsh)"

# fzf —— 模糊搜索。Ctrl-T(选文件), Ctrl-R(历史，由 atuin 接管), Alt-C(切目录)
source <(fzf --zsh)
# 让 fzf 用 fd 来列举文件（更快，且尊重 .gitignore）
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
# fzf 外观：Anthropic 暖色 + 圆角边框
export FZF_DEFAULT_OPTS="
  --height 60% --layout=reverse --border=rounded --margin=1 --padding=1
  --prompt='  ' --pointer='▶' --marker='✓'
  --color=bg+:#E5DECB,fg:#141413,fg+:#141413,hl:#C24A2E,hl+:#C24A2E
  --color=info:#8A857A,border:#D97757,prompt:#D97757,pointer:#D97757,marker:#5F7F4B,header:#8A857A,spinner:#D97757"
# Ctrl-T 选文件用 bat 预览，Alt-C 切目录用 eza 预览
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --color=always --icons {}'"

# eza —— 现代化的 ls 替代品
alias ls='eza --group-directories-first --icons'
alias ll='eza -lah --group-directories-first --icons --git'
alias la='eza -a --group-directories-first --icons'
alias lt='eza --tree --level=2 --icons'

# bat —— 带语法高亮的 cat
alias cat='bat'   # 主题/样式见 ~/.config/bat/config

# ripgrep —— 让 rg 读取配置文件（智能大小写、排除规则、配色）
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/ripgreprc"

# zsh 历史最佳实践（atuin 也会读取）
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY          # 多终端共享历史
setopt HIST_IGNORE_ALL_DUPS   # 去重
setopt HIST_REDUCE_BLANKS     # 压缩多余空白
setopt HIST_VERIFY            # 历史展开后先回显再执行
setopt EXTENDED_HISTORY       # 记录时间戳
setopt INC_APPEND_HISTORY     # 立即写入
setopt AUTO_CD                # 输入目录名直接 cd
setopt INTERACTIVE_COMMENTS   # 交互式下允许 # 注释

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

